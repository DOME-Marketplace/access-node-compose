# DOME Access Node - LOCAL Environment Configuration
# DO NOT COMMIT THIS FILE TO GIT - Add to .gitignore

# =============================================================================
# PROJECT
# =============================================================================
COMPOSE_PROJECT_NAME=dome

# =============================================================================
# IMAGES
# =============================================================================
# Official DOME images - can be overridden with local builds if needed

# Scorpio Context Broker
SCORPIO_IMAGE=scorpiobroker/all-in-one-runner:java-4.1.11

# Desmos: Use official image from Docker Hub or build locally
# Official: in2workspace/in2-desmos-api:v2.0.2 (recommended version)
# Local build: dome/desmos:local (requires building from source)
DESMOS_IMAGE=in2workspace/in2-desmos-api:v2.0.2

# DLT-Adapter: Use official image from Quay.io
DLT_ADAPTER_IMAGE=quay.io/digitelts/dlt-adapter:1.5.1

# =============================================================================
# SCORPIO DATABASE
# =============================================================================
SCORPIO_DB_NAME=scorpio
SCORPIO_DB_USER=scorpio
SCORPIO_DB_PASSWORD=changeme_scorpio_local

# =============================================================================
# DESMOS DATABASE
# =============================================================================
DESMOS_DB_NAME=desmos
DESMOS_DB_USER=desmos
DESMOS_DB_PASSWORD=changeme_desmos_local

# =============================================================================
# REDIS
# =============================================================================
REDIS_PASSWORD=changeme_redis_local

# =============================================================================
# ORGANIZATION IDENTITY (DOME Credentials)
# =============================================================================
# Generate these using: https://dome-marketplace.github.io/dome-crypto-generator/
# For production: generate real keys
# For local development: using test keys from application-dev.yml

# Organization DID (format: did:key:z6Mk...)
# For local dev, using a test DID
ORGANIZATION_DID=did:key:z6MkigCEnopwujz8Ten2dzq91xZGp1SH2hkYW4iZJjkbPaq7

# Desmos Private Key (hex format with 0x prefix from application-dev.yml)
# This is a TEST key from the Desmos dev configuration - DO NOT use in production
DESMOS_PRIVATE_KEY=0x1aff50dca1ac463a5af99a858c2eef7517b8e46d3bf84723ff6dcfead7dc8db6

# =============================================================================
# DLT / BLOCKCHAIN CONFIGURATION
# =============================================================================
# Ethereum private key (hex format, 64 characters)
DLT_PRIVATE_KEY=GENERATE_ME

# Ethereum address (derived from private key)
DLT_ADDRESS=0xGENERATE_ME

# ISS - SHA-256 hash of organization identifier
DLT_ISS=GENERATE_ME

# Alastria RPC endpoint (use sandbox for local/testing)
ALASTRIA_RPC_ENDPOINT=https://rpc-sandbox.alastria.io

# Polling configuration (milliseconds)
DLT_POLLING_INTERVAL=10000
DLT_POLLING_BLOCK_RANGE=100

# =============================================================================
# EXTERNAL DOMAIN
# =============================================================================
# The public domain where your DOME Access Node is accessible from outside
# Used in blockchain events for sourceUrl and API advertisements
# For local development: use localhost (accessible from host machine)
# For production: use your actual public domain

EXTERNAL_DOMAIN_PROTOCOL=http
EXTERNAL_DOMAIN=localhost:8081

# =============================================================================
# LEAR CREDENTIAL
# =============================================================================
# Obtain via DOME ticketing system: https://ticketing.dome-marketplace.eu/
# Base64 encoded LEAR Credential
# For local dev: can be empty (dev profile doesn't require it)

LEAR_CREDENTIAL=

# =============================================================================
# DESMOS CONFIGURATION
# =============================================================================
DESMOS_PROFILE=dev
DESMOS_LOG_LEVEL=DEBUG

# =============================================================================
# DLT-ADAPTER CONFIGURATION
# =============================================================================
DLT_LOG_LEVEL=debug

# =============================================================================
# TMFORUM API CONFIGURATION
# =============================================================================
TMFORUM_LOG_LEVEL=INFO

# TMForum API Images (override if needed)
# TMFORUM_PRODUCT_CATALOG_IMAGE=quay.io/fiware/tmforum-product-catalog:0.25.1
# TMFORUM_PARTY_CATALOG_IMAGE=quay.io/fiware/tmforum-party-catalog:0.25.1
# TMFORUM_PRODUCT_ORDERING_IMAGE=quay.io/fiware/tmforum-product-ordering-management:0.25.1
# TMFORUM_SERVICE_CATALOG_IMAGE=quay.io/fiware/tmforum-service-catalog:0.25.1

# =============================================================================
# NOTES FOR LOCAL DEVELOPMENT
# =============================================================================
# 1. Generate cryptographic keys using DOME key generator tool
# 2. Request LEAR Credential via DOME ticketing (use sandbox for testing)
# 3. For local testing, you may use mock/test values for LEAR_CREDENTIAL
# 4. External domain must be accessible from other DOME nodes
#    - For local testing, consider using ngrok or similar tunnel
#    - Or just test internal functionality without external replication
# 5. Build Desmos and DLT-Adapter images from source:
#    - docker build -t dome/desmos:local ./references/external/desmos
#    - docker build -t dome/dlt-adapter:local ./references/external/DOME-blockchain_connector-dlt_interface
